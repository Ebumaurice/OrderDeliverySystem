{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=OrderDeliveryDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "ApiKey": "f7d2a1b9-3e4c-5f8a-9b2d-1c6e5f0a3d7e",
  "AllowedHosts": "*"
}